DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iplpredictiongame_dev"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/iplpredictiongame_dev"

AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Set either AUTH_URL or NEXTAUTH_URL. AUTH_URL is preferred here.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Bootstrap room code used only for the initial default room if the database has no rooms yet.
PRIVATE_ROOM_CODE="MYIPL2026"
ADMIN_EMAILS="admin@example.com"
# Bootstrap allowlist setting for the initial default room only.
ALLOWLIST_ENABLED="false"
DEFAULT_CUTOFF_MINUTES="60"

# Local integration test database
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iplpredictiongame_test"
TEST_DIRECT_URL="postgresql://postgres:postgres@localhost:5432/iplpredictiongame_test"
